# URL base del endpoint compatible con OpenAI — incluye el path hasta antes de /chat/completions
# Google AI Studio:  https://generativelanguage.googleapis.com/v1beta/openai
# LiteLLM:           http://litellm:4000/v1
# OpenAI:            https://api.openai.com/v1
AI_ENDPOINT=https://generativelanguage.googleapis.com/v1beta/openai

# Clave API del proveedor (LiteLLM key, OpenAI key, etc.)
AI_API_KEY=sk-...

# Modelo a usar (por defecto gemini-2.0-flash-lite)
AI_MODEL=gemini-2.0-flash-lite

# Token del tunnel de Cloudflare (obtenido desde Zero Trust → Tunnels)
TUNNEL_TOKEN=eyJ...
