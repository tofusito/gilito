# URL base del endpoint compatible con OpenAI (ej: LiteLLM, OpenAI, etc.)
AI_ENDPOINT=http://litellm:4000

# Clave API del proveedor (LiteLLM key, OpenAI key, etc.)
AI_API_KEY=sk-...

# Modelo a usar (por defecto gemini-2.0-flash-lite)
AI_MODEL=gemini-2.0-flash-lite

# Token del tunnel de Cloudflare (obtenido desde Zero Trust → Tunnels)
TUNNEL_TOKEN=eyJ...
