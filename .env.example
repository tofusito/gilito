# API key de Google AI Studio (aistudio.google.com)
GEMINI_API_KEY=AIza...

# Modelo a usar (por defecto gemini-2.0-flash-lite)
AI_MODEL=gemini-2.0-flash-lite

# Tamaño máximo de imagen para escaneo, en bytes (6 MiB por defecto)
SCAN_MAX_BYTES=6291456

# Timeout de Gemini en milisegundos
GEMINI_TIMEOUT_MS=15000

# Máximo de monedas aceptadas en una restauración de backup
MAX_IMPORT_COINS=10000

# Token del tunnel de Cloudflare (Zero Trust → Tunnels)
TUNNEL_TOKEN=eyJ...
